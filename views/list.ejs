<!doctype html>
<html lang="tr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Davetli Listesi</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="min-h-screen bg-slate-100">
  <% const filterUsersList = typeof filterUsers !== 'undefined' ? filterUsers : []; %>
  <% const filterCitiesList = typeof filterCities !== 'undefined' ? filterCities : []; %>
  <% const hasUnassignedGuestsFlag = typeof hasUnassignedGuests !== 'undefined' ? hasUnassignedGuests : false; %>
  <% const hasEmptyCityGuestsFlag = typeof hasEmptyCityGuests !== 'undefined' ? hasEmptyCityGuests : false; %>
  <%- include('partials/nav', { username, readOnly }) %>

  <main class="max-w-7xl mx-auto p-4 sm:p-6 space-y-6">
    <section class="stats-grid grid grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-2 sm:gap-3">
      <div class="stats-card stats-card-emerald col-span-2 md:col-span-1 rounded-lg sm:rounded-xl bg-emerald-600 text-white p-2 sm:p-2.5">
        <p class="text-[11px] sm:text-xs leading-tight">Kesin Gelecekler (1)</p>
        <p class="text-lg sm:text-xl font-bold leading-none mt-0.5" id="count-1"><%= stats.count1 %></p>
        <p class="text-[10px] sm:text-xs mt-1 text-emerald-100 leading-tight">LCV onayi</p>
        <p class="text-sm sm:text-base font-bold leading-tight" id="confirmed-guests-ratio"><%= Number(stats.confirmedGuestCount || 0) %> / <%= stats.count1 %> onayladi</p>
        <p class="text-[10px] sm:text-xs mt-0.5 text-emerald-100 leading-tight" id="confirmed-persons"><%= Number(stats.confirmedPersons || 0) %> kisi gelecek</p>
        <p class="text-[10px] sm:text-xs mt-1 text-emerald-100 leading-tight">LCV katilmayan (0 kisi)</p>
        <p class="text-sm sm:text-base font-bold leading-none" id="declined-rsvp-count"><%= Number(stats.declinedRsvpCount || 0) %></p>
      </div>
      <div class="stats-card rounded-lg sm:rounded-xl bg-amber-500 text-white p-2 sm:p-2.5"><p class="text-[11px] sm:text-xs leading-tight">Belirsizler (2)</p><p class="text-lg sm:text-xl font-bold leading-none mt-0.5" id="count-2"><%= stats.count2 %></p></div>
      <div class="stats-card rounded-lg sm:rounded-xl bg-rose-600 text-white p-2 sm:p-2.5"><p class="text-[11px] sm:text-xs leading-tight">Elenenler / Yedekler (3)</p><p class="text-lg sm:text-xl font-bold leading-none mt-0.5" id="count-3"><%= stats.count3 %></p></div>
      <div class="stats-card rounded-lg sm:rounded-xl bg-slate-800 text-white p-2 sm:p-2.5"><p class="text-[11px] sm:text-xs leading-tight">Toplam Davetli</p><p class="text-lg sm:text-xl font-bold leading-none mt-0.5" id="total-guests"><%= stats.totalGuests %></p></div>
      <div class="stats-card rounded-lg sm:rounded-xl bg-indigo-700 text-white p-2 sm:p-2.5 md:col-span-2 xl:col-span-1"><p class="text-[11px] sm:text-xs leading-tight">Kapasite / Doluluk</p><p class="text-xs sm:text-sm leading-tight mt-0.5"><%= stats.capacity %> kisi</p><p class="text-base sm:text-lg font-bold leading-none mt-0.5" id="occupancy-rate"><%= stats.occupancyRate %>%</p></div>
    </section>

    <section class="bg-white rounded-2xl overflow-hidden border">
      <div class="p-4 border-b flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <h1 class="text-lg font-semibold">Davetli Listesi</h1>
        <div class="flex flex-col sm:flex-row sm:items-center gap-2 ml-auto w-full sm:w-auto">
          <label class="flex items-center gap-2 text-sm text-slate-600 shrink-0">
            <span class="whitespace-nowrap font-medium">Kullanici</span>
            <select id="userFilter" class="table-filter-select rounded-lg border border-slate-300 bg-white px-2 py-1.5 text-sm min-w-[9rem] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none">
              <option value="">Tumu</option>
              <% if (hasUnassignedGuestsFlag) { %><option value="__none__">—</option><% } %>
              <% for (const u of filterUsersList) { %><option value="<%= u.id %>"><%= u.username %></option><% } %>
            </select>
            <span id="filteredGuestCount" class="text-slate-500 text-sm tabular-nums whitespace-nowrap" title="Filtreye uyan satir / tablodaki tum satirlar"></span>
          </label>
          <label class="flex items-center gap-2 text-sm text-slate-600 shrink-0">
            <span class="whitespace-nowrap font-medium">Sehir</span>
            <select id="cityFilter" class="table-filter-select rounded-lg border border-slate-300 bg-white px-2 py-1.5 text-sm min-w-[9rem] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none">
              <option value="">Tumu</option>
              <% if (hasEmptyCityGuestsFlag) { %><option value="__none__">—</option><% } %>
              <% for (const c of filterCitiesList) { %><option value="<%= c.city %>"><%= c.city %></option><% } %>
            </select>
          </label>
          <div class="table-search w-full sm:w-auto">
            <input type="search" id="tableSearch" class="table-search-input" placeholder="Tabloda ara..." autocomplete="off" spellcheck="false">
            <button type="button" id="tableSearchClear" class="table-search-clear" aria-label="Aramayi temizle" title="Temizle">
              <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true"><path stroke="currentColor" stroke-linecap="round" stroke-width="2" fill="none" d="m3 3 8 8M11 3l-8 8"/></svg>
            </button>
          </div>
        </div>
      </div>
      <div id="tableWrap" class="guest-table-scroll">
        <table class="min-w-full text-sm">
          <thead class="bg-slate-50"><tr><th class="px-4 py-3 text-left" title="Isme gore siralama"><button type="button" class="sort-btn inline-flex items-center gap-1 font-semibold text-left text-slate-800 hover:text-indigo-700" data-sort-key="name" aria-label="Ad Soyad sirala">Ad Soyad <span class="sort-indicator text-slate-400" aria-hidden="true">A-Z</span></button></th><% if (!readOnly) { %><th class="px-4 py-3 text-left">Telefon</th><th class="px-4 py-3 text-left guest-col-email">Email</th><% } %><th class="px-4 py-3 text-left" title="Sehire gore siralama"><button type="button" class="sort-btn inline-flex items-center gap-1 font-semibold text-left text-slate-800 hover:text-indigo-700" data-sort-key="city" aria-label="Sehir sirala">Sehir <span class="sort-indicator text-slate-400" aria-hidden="true"></span></button></th><th class="px-4 py-3 text-left" title="Statusa gore siralama"><button type="button" class="sort-btn inline-flex items-center gap-1 font-semibold text-left text-slate-800 hover:text-indigo-700" data-sort-key="status" aria-label="Status sirala">Status <span class="sort-indicator text-slate-400" aria-hidden="true"></span></button></th><th class="px-4 py-3 text-left" title="Kisi sayisina gore siralama"><button type="button" class="sort-btn inline-flex items-center gap-1 font-semibold text-left text-slate-800 hover:text-indigo-700" data-sort-key="party" aria-label="Kisi sirala">Kisi <span class="sort-indicator text-slate-400" aria-hidden="true"></span></button></th><th class="px-4 py-3 text-left">LCV Notu</th><th class="px-4 py-3 text-left">Davet Linki</th><th class="px-4 py-3 text-left">Kullanici</th><% if (!readOnly) { %><th class="px-4 py-3 text-left whitespace-nowrap">Islem</th><% } %></tr></thead>
          <tbody>
            <% for (const g of guests) {
              const guestUserId = g.user_id == null ? null : Number(g.user_id);
              const ownsGuest = guestUserId !== null && guestUserId === currentUserId;
              const canManage = isAdmin || ownsGuest;
              const canSeeContact = isAdmin || ownsGuest;
            %>
            <% const partySizeVal = g.party_size; const hasRsvp = !!g.rsvp_at; const isRsvpDeclined = hasRsvp && Number(partySizeVal) === 0; %>
            <tr class="border-t guest-row<%= isRsvpDeclined ? ' guest-row-rsvp-declined' : '' %>" data-id="<%= g.id %>" data-name="<%= g.name %>"<% if (canSeeContact) { %> data-phone="<%= g.phone || "" %>" data-email="<%= g.email || "" %>"<% } %> data-city="<%= g.city || "" %>" data-status="<%= g.status %>" data-user-id="<%= g.user_id == null ? "" : g.user_id %>" data-can-manage="<%= canManage ? "1" : "0" %>" data-party-size="<%= partySizeVal != null ? partySizeVal : "" %>" data-rsvp="<%= hasRsvp ? "1" : "0" %>">
              <td class="px-4 py-3 font-medium guest-cell-name"><%= g.name %></td>
              <% if (!readOnly) { %><td class="px-4 py-3 guest-cell-phone text-slate-500"><%= canSeeContact ? (g.phone || "") : "—" %></td><td class="px-4 py-3 guest-cell-email text-slate-500" title="<%= canSeeContact ? (g.email || "") : "" %>"><%= canSeeContact ? (g.email || "") : "—" %></td><% } %>
              <td class="px-4 py-3 guest-cell-city"><%= g.city || "" %></td>
              <td class="px-4 py-3 guest-cell-status align-top">
                <% if (readOnly || !canManage) { %>
                <span class="inline-block text-xs font-medium px-2 py-1 rounded status-badge status-<%= g.status %>"><%= g.status %> - <%= g.status === 1 ? "Mutlaka" : (g.status === 2 ? "Olabilir" : "Gerek Yok") %></span>
                <% } else { %>
                <div class="status-control">
                  <button type="button" class="status-btn status-<%= g.status %>" data-id="<%= g.id %>" data-status="<%= g.status %>" aria-label="Status: <%= g.status === 1 ? "Mutlaka" : (g.status === 2 ? "Olabilir" : "Gerek Yok") %>" title="Status degistirmek icin tiklayin"><%= g.status === 1 ? "E" : (g.status === 2 ? "O" : "H") %></button>
                </div>
                <% } %>
              </td>
              <td class="px-4 py-3 guest-cell-party text-slate-700 whitespace-nowrap">
                <% if (partySizeVal != null && partySizeVal !== '') { %>
                  <% if (isRsvpDeclined) { %>
                  <span class="party-size-declined" title="LCV: Katilamiyor">0</span>
                  <% } else { %>
                  <%= partySizeVal %>
                  <% } %>
                <% } else { %>—<% } %>
              </td>
              <td class="px-4 py-3 guest-cell-rsvp-note text-slate-600 max-w-[12rem] truncate" title="<%= g.rsvp_note || "" %>"><%= g.rsvp_note || "—" %></td>
              <td class="px-4 py-3 guest-cell-invite align-top">
                <% if (g.invite_token) { %>
                <% const inviteUrl = `${typeof baseUrl !== "undefined" ? baseUrl : ""}/davet/${g.invite_token}`; %>
                <button type="button" class="invite-copy-btn" data-url="<%= inviteUrl %>" title="<%= inviteUrl %>">Link</button>
                <% } else { %>
                <span class="text-slate-400 text-xs">—</span>
                <% } %>
              </td>
              <td class="px-4 py-3 guest-cell-kullanici text-slate-600 whitespace-nowrap" title="<%= g.kullanici || "" %>"><%= g.kullanici ? String(g.kullanici).slice(0, 3) : "—" %></td>
              <% if (!readOnly) { %>
              <td class="px-4 py-3 guest-cell-actions align-top">
                <% if (canManage) { %>
                <div class="guest-actions">
                  <button type="button" class="guest-edit-btn px-2 py-1 rounded text-xs font-medium bg-indigo-600 text-white hover:bg-indigo-700">Duzenle</button>
                  <button type="button" class="guest-delete-btn px-2 py-1 rounded text-xs font-medium bg-rose-600 text-white hover:bg-rose-700">Sil</button>
                </div>
                <% } %>
              </td>
              <% } %>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
      <div class="guest-table-pagination">
        <div class="guest-page-nav flex items-center gap-2 flex-wrap">
          <button type="button" id="pagePrev" class="guest-page-nav-btn" aria-label="Onceki sayfa">Onceki</button>
          <p id="pageInfo" class="guest-page-info text-sm text-slate-600 tabular-nums"></p>
          <button type="button" id="pageNext" class="guest-page-nav-btn" aria-label="Sonraki sayfa">Sonraki</button>
        </div>
        <label class="guest-page-select-label flex items-center gap-2 text-sm text-slate-700">
          <span class="font-medium whitespace-nowrap">Sayfada</span>
          <select id="pageSizeSelect" class="guest-page-select rounded-lg border border-slate-300 bg-white px-2 py-1.5 text-sm min-w-[5rem] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none" aria-label="Sayfa basina kayit sayisi">
            <option value="10" selected>10</option>
            <option value="25">25</option>
            <option value="50">50</option>
            <option value="100">100</option>
            <option value="150">150</option>
            <option value="250">250</option>
            <option value="500">500</option>
          </select>
          <span class="whitespace-nowrap">kayit goster</span>
        </label>
      </div>
    </section>
  </main>

  <script>
  const READ_ONLY = <%= readOnly ? 'true' : 'false' %>;
  const GUEST_API = { prefix: '/api/guest' };
  const statusTextMap = {1:'Mutlaka',2:'Olabilir',3:'Gerek Yok'};
  const statusLetterMap = {1:'E',2:'O',3:'H'};
  const CURRENT_USER_ID = <%= typeof currentUserId !== "undefined" ? Number(currentUserId || 0) : 0 %>;
  const IS_ADMIN = <%= typeof isAdmin !== "undefined" && isAdmin ? "true" : "false" %>;
  let editingRow = null;

  function canManageGuestRow(tr){
    if(IS_ADMIN) return true;
    return tr.dataset.canManage === '1';
  }
  function canSeeContactRow(tr){
    if(IS_ADMIN) return true;
    return tr.dataset.canManage === '1';
  }

  function updateStatusBtnStyle(btn, status){
    btn.classList.remove('status-1','status-2','status-3');
    btn.classList.add(`status-${status}`);
    btn.dataset.status = String(status);
    btn.textContent = statusLetterMap[status];
    btn.setAttribute('aria-label', `Status: ${statusTextMap[status]}`);
    btn.title = 'Status degistirmek icin tiklayin';
  }
  function nextStatus(current){ return current >= 3 ? 1 : current + 1; }
  function updateConfirmedStats(stats) {
    const ratio = document.getElementById('confirmed-guests-ratio');
    const persons = document.getElementById('confirmed-persons');
    if (ratio) ratio.textContent = `${Number(stats.confirmed_guest_count ?? 0)} / ${Number(stats.count_1 ?? 0)} onayladi`;
    if (persons) persons.textContent = `${Number(stats.confirmed_persons ?? 0)} kisi gelecek`;
  }
  function updateStats(stats){
    document.getElementById('count-1').textContent=stats.count_1;
    document.getElementById('count-2').textContent=stats.count_2;
    document.getElementById('count-3').textContent=stats.count_3;
    document.getElementById('total-guests').textContent=stats.total_guests;
    document.getElementById('occupancy-rate').textContent=`${stats.occupancy_rate}%`;
    updateConfirmedStats(stats);
    const dr=document.getElementById('declined-rsvp-count');
    if(dr) dr.textContent=String(stats.declined_rsvp_count ?? 0);
  }

  function guestRowNameForSort(tr){
    const cell = tr.querySelector('.guest-cell-name');
    if(!cell) return '';
    const inp = cell.querySelector('input.guest-inline-field');
    if(inp) return String(inp.value || '').trim();
    return String(cell.textContent || '').trim();
  }
  const sortState = { key: 'name', direction: 'asc' };

  function guestRowCityForSort(tr){
    const cell = tr.querySelector('.guest-cell-city');
    if(!cell) return '';
    const inp = cell.querySelector('input.guest-inline-field');
    if(inp) return String(inp.value || '').trim();
    return String(cell.textContent || '').trim();
  }
  function guestRowStatusForSort(tr){
    return Number(tr.dataset.status || 0);
  }
  function guestRowPartyForSort(tr){
    const raw = tr.dataset.partySize;
    if(raw === '' || raw == null) return -1;
    return Number(raw);
  }
  function sortDirectionFactor(){
    return sortState.direction === 'asc' ? 1 : -1;
  }
  function compareGuestRows(a,b){
    if(sortState.key === 'status'){
      const diff = (guestRowStatusForSort(a) - guestRowStatusForSort(b)) * sortDirectionFactor();
      if(diff !== 0) return diff;
      return guestRowNameForSort(a).localeCompare(guestRowNameForSort(b), 'tr', { sensitivity: 'base' });
    }
    if(sortState.key === 'city'){
      const cmp = guestRowCityForSort(a).localeCompare(guestRowCityForSort(b), 'tr', { sensitivity: 'base' }) * sortDirectionFactor();
      if(cmp !== 0) return cmp;
      return guestRowNameForSort(a).localeCompare(guestRowNameForSort(b), 'tr', { sensitivity: 'base' });
    }
    if(sortState.key === 'party'){
      const diff = (guestRowPartyForSort(a) - guestRowPartyForSort(b)) * sortDirectionFactor();
      if(diff !== 0) return diff;
      return guestRowNameForSort(a).localeCompare(guestRowNameForSort(b), 'tr', { sensitivity: 'base' });
    }
    return guestRowNameForSort(a).localeCompare(guestRowNameForSort(b), 'tr', { sensitivity: 'base' }) * sortDirectionFactor();
  }
  function refreshSortIndicators(){
    const buttons = document.querySelectorAll('.sort-btn');
    buttons.forEach((btn)=>{
      const key = btn.dataset.sortKey;
      const indicator = btn.querySelector('.sort-indicator');
      if(!indicator) return;
      if(key !== sortState.key){
        indicator.textContent = '';
        btn.classList.remove('text-indigo-700');
        return;
      }
      if(key === 'name') indicator.textContent = sortState.direction === 'asc' ? 'A-Z' : 'Z-A';
      if(key === 'city') indicator.textContent = sortState.direction === 'asc' ? 'A-Z' : 'Z-A';
      if(key === 'status') indicator.textContent = sortState.direction === 'asc' ? '1-3' : '3-1';
      if(key === 'party') indicator.textContent = sortState.direction === 'asc' ? '0-5' : '5-0';
      btn.classList.add('text-indigo-700');
    });
  }
  function sortGuestTable(){
    if(editingRow) return;
    const tbody = document.querySelector('#tableWrap tbody');
    if(!tbody) return;
    const rows = Array.from(tbody.querySelectorAll('tr.guest-row'));
    rows.sort(compareGuestRows);
    for(const r of rows) tbody.appendChild(r);
    refreshSortIndicators();
  }
  function setSort(key){
    if(sortState.key === key){
      sortState.direction = sortState.direction === 'asc' ? 'desc' : 'asc';
    }else{
      sortState.key = key;
      sortState.direction = 'asc';
    }
    sortGuestTable();
    applyTableFilter();
  }

  function statusCellHtml(id, status){
    return `<div class="status-control">
      <button type="button" class="status-btn status-${status}" data-id="${id}" data-status="${status}" aria-label="Status: ${statusTextMap[status]}" title="Status degistirmek icin tiklayin">${statusLetterMap[status]}</button>
    </div>`;
  }
  function statusBadgeHtml(status){
    return `<span class="inline-block text-xs font-medium px-2 py-1 rounded status-badge status-${status}">${status} - ${statusTextMap[status]}</span>`;
  }
  function actionsCellHtml(){
    return `<div class="guest-actions">
      <button type="button" class="guest-edit-btn px-2 py-1 rounded text-xs font-medium bg-indigo-600 text-white hover:bg-indigo-700">Duzenle</button>
      <button type="button" class="guest-delete-btn px-2 py-1 rounded text-xs font-medium bg-rose-600 text-white hover:bg-rose-700">Sil</button>
    </div>`;
  }

  function cancelInlineEdit(tr){
    if(!tr || !tr._inlineBackup) return;
    const b = tr._inlineBackup;
    tr.querySelector('.guest-cell-name').innerHTML = b.name;
    tr.querySelector('.guest-cell-phone').innerHTML = b.phone;
    tr.querySelector('.guest-cell-email').innerHTML = b.email;
    tr.querySelector('.guest-cell-city').innerHTML = b.city;
    tr.querySelector('.guest-cell-status').innerHTML = b.status;
    tr.querySelector('.guest-cell-actions').innerHTML = b.actions;
    delete tr._inlineBackup;
    if(editingRow === tr) editingRow = null;
    tr.classList.remove('guest-row-editing');
  }

  function startInlineEdit(tr){
    if(!canManageGuestRow(tr)) return;
    if(tr._inlineBackup) return;
    if(editingRow && editingRow !== tr) cancelInlineEdit(editingRow);
    const nameTd = tr.querySelector('.guest-cell-name');
    const phoneTd = tr.querySelector('.guest-cell-phone');
    const emailTd = tr.querySelector('.guest-cell-email');
    const cityTd = tr.querySelector('.guest-cell-city');
    const statusTd = tr.querySelector('.guest-cell-status');
    const actionsTd = tr.querySelector('.guest-cell-actions');
    tr._inlineBackup = { name: nameTd.innerHTML, phone: phoneTd.innerHTML, email: emailTd.innerHTML, city: cityTd.innerHTML, status: statusTd.innerHTML, actions: actionsTd.innerHTML };
    editingRow = tr;
    tr.classList.add('guest-row-editing');

    const inpName = document.createElement('input');
    inpName.type = 'text';
    inpName.required = true;
    inpName.className = 'guest-inline-field w-full min-w-[10rem] rounded border border-indigo-200 px-2 py-1 text-sm font-medium';
    inpName.value = tr.dataset.name || '';
    nameTd.replaceChildren(inpName);

    const inpPhone = document.createElement('input');
    inpPhone.type = 'text';
    inpPhone.className = 'guest-inline-field w-full min-w-[7rem] rounded border border-indigo-200 px-2 py-1 text-sm';
    inpPhone.value = tr.dataset.phone || '';
    phoneTd.replaceChildren(inpPhone);

    const inpEmail = document.createElement('input');
    inpEmail.type = 'email';
    inpEmail.className = 'guest-inline-field w-full min-w-[10rem] rounded border border-indigo-200 px-2 py-1 text-sm';
    inpEmail.value = tr.dataset.email || '';
    emailTd.replaceChildren(inpEmail);

    const inpCity = document.createElement('input');
    inpCity.type = 'text';
    inpCity.className = 'guest-inline-field w-full min-w-[7rem] rounded border border-indigo-200 px-2 py-1 text-sm';
    inpCity.value = tr.dataset.city || '';
    cityTd.replaceChildren(inpCity);

    const sel = document.createElement('select');
    sel.className = 'guest-inline-status w-full max-w-[12rem] rounded border border-indigo-200 px-2 py-1 text-sm';
    [[1,'1 - Mutlaka'],[2,'2 - Olabilir'],[3,'3 - Gerek Yok']].forEach(([v,t])=>{ const o=document.createElement('option'); o.value=v; o.textContent=t; sel.appendChild(o); });
    sel.value = String(tr.dataset.status || '2');
    statusTd.replaceChildren(sel);

    const wrap = document.createElement('div');
    wrap.className = 'guest-actions';
    const btnSave = document.createElement('button');
    btnSave.type = 'button';
    btnSave.className = 'guest-inline-save px-2 py-1 rounded text-xs font-medium bg-emerald-600 text-white hover:bg-emerald-700';
    btnSave.textContent = 'Kaydet';
    const btnCancel = document.createElement('button');
    btnCancel.type = 'button';
    btnCancel.className = 'guest-inline-cancel px-2 py-1 rounded text-xs font-medium border border-slate-300 bg-white hover:bg-slate-50';
    btnCancel.textContent = 'Iptal';
    wrap.append(btnSave, btnCancel);
    actionsTd.replaceChildren(wrap);
    inpName.focus();
  }

  async function saveInlineEdit(tr){
    const id = Number(tr.dataset.id);
    const name = tr.querySelector('.guest-cell-name input')?.value.trim() || '';
    const phone = tr.querySelector('.guest-cell-phone input')?.value.trim() || '';
    const email = tr.querySelector('.guest-cell-email input')?.value.trim() || '';
    const city = tr.querySelector('.guest-cell-city input')?.value.trim() || '';
    const status = Number(tr.querySelector('.guest-inline-status')?.value || 0);
    if(!name){ alert('Ad Soyad zorunludur'); return; }
    const res = await fetch(`${GUEST_API.prefix}/${id}`, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ name, phone, email, city, status }) });
    const ct = res.headers.get('content-type') || '';
    const data = ct.includes('application/json') ? await res.json() : { success: false, message: await res.text().catch(()=>'Sunucu yaniti gecersiz') };
    if(!res.ok || !data.success){ alert(data.message || 'Kayit guncellenemedi'); return; }
    delete tr._inlineBackup;
    editingRow = null;
    tr.classList.remove('guest-row-editing');
    tr.dataset.name = name;
    tr.dataset.city = city;
    tr.dataset.status = String(status);
    if(canSeeContactRow(tr)){
      tr.dataset.phone = phone;
      tr.dataset.email = email;
    }
    tr.dataset.canManage = '1';
    tr.dataset.userId = String(CURRENT_USER_ID || '');
    tr.querySelector('.guest-cell-name').textContent = name;
    tr.querySelector('.guest-cell-phone').textContent = canSeeContactRow(tr) ? phone : '—';
    tr.querySelector('.guest-cell-email').textContent = canSeeContactRow(tr) ? email : '—';
    tr.querySelector('.guest-cell-city').textContent = city;
    tr.querySelector('.guest-cell-status').innerHTML = canManageGuestRow(tr) ? statusCellHtml(id, status) : statusBadgeHtml(status);
    tr.querySelector('.guest-cell-actions').innerHTML = actionsCellHtml();
    updateStats(data.stats);
    sortGuestTable();
    applyTableFilter();
  }

  async function updateGuestStatus(id, status, btn){
    const res = await fetch('/api/update',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id,status})});
    const data = await res.json();
    if(!res.ok || !data.success){ alert(data.message || 'Guncelleme basarisiz'); return; }
    updateStatusBtnStyle(btn, status);
    const tr = btn.closest('.guest-row');
    if(tr) tr.dataset.status = String(status);
    updateStats(data.stats);
  }

  const tableWrap = document.getElementById('tableWrap');
  if (!READ_ONLY) tableWrap.addEventListener('click', (e)=>{
    const btn = e.target.closest('.status-btn');
    if(!btn) return;
    const tr = btn.closest('.guest-row');
    if(tr && !canManageGuestRow(tr)) return;
    const current = Number(btn.dataset.status || 1);
    const status = nextStatus(current);
    const id = Number(btn.dataset.id);
    updateGuestStatus(id, status, btn);
  });

  if (!READ_ONLY) tableWrap.addEventListener('click', async (e)=>{
    if(e.target.closest('.status-btn')) return;
    if(e.target.closest('.guest-inline-save')){
      await saveInlineEdit(e.target.closest('.guest-row'));
      return;
    }
    if(e.target.closest('.guest-inline-cancel')){
      cancelInlineEdit(e.target.closest('.guest-row'));
      return;
    }
    if(e.target.closest('.guest-edit-btn')){
      startInlineEdit(e.target.closest('.guest-row'));
      return;
    }
    const delBtn = e.target.closest('.guest-delete-btn');
    if(delBtn){
      const tr = delBtn.closest('.guest-row');
      const id = Number(tr.dataset.id);
      if(!id || !confirm('Bu davetliyi silmek istediginize emin misiniz?')) return;
      const res = await fetch(`${GUEST_API.prefix}/${id}`, { method:'DELETE' });
      const data = await res.json();
      if(!res.ok || !data.success){ alert(data.message || 'Silme basarisiz'); return; }
      if(editingRow === tr) editingRow = null;
      tr.remove();
      updateStats(data.stats);
      applyTableFilter();
    }
  });

  const tableSearch = document.getElementById('tableSearch');
  const tableSearchClear = document.getElementById('tableSearchClear');
  const userFilter = document.getElementById('userFilter');
  const cityFilter = document.getElementById('cityFilter');
  const filteredGuestCountEl = document.getElementById('filteredGuestCount');
  const pageSizeSelect = document.getElementById('pageSizeSelect');
  const pagePrev = document.getElementById('pagePrev');
  const pageNext = document.getElementById('pageNext');
  const pageInfo = document.getElementById('pageInfo');
  let pageSize = Number(pageSizeSelect?.value || 10);
  let currentPage = 1;
  const tableRows = () => document.querySelectorAll('#tableWrap tbody tr.guest-row');

  function rowMatchesFilter(tr, q, userId, city) {
    const hay = tr.innerText.toLowerCase().replace(/\s+/g, ' ');
    const matchSearch = !q || hay.includes(q);
    const rowUserId = tr.dataset.userId || '';
    const matchUser = !userId || (userId === '__none__' ? !rowUserId : rowUserId === userId);
    const rowCity = tr.dataset.city || '';
    const matchCity = !city || (city === '__none__' ? !rowCity : rowCity === city);
    return matchSearch && matchUser && matchCity;
  }

  function updatePageNav(totalPages) {
    if (pagePrev) pagePrev.disabled = currentPage <= 1;
    if (pageNext) pageNext.disabled = currentPage >= totalPages;
  }

  function updatePageInfo(matchedCount, totalPages) {
    if (!pageInfo) return;
    if (!matchedCount) {
      pageInfo.textContent = 'Kayit bulunamadi';
      updatePageNav(1);
      return;
    }
    const start = (currentPage - 1) * pageSize + 1;
    const end = Math.min(currentPage * pageSize, matchedCount);
    pageInfo.textContent = `${start}-${end} / ${matchedCount} kayit · Sayfa ${currentPage} / ${totalPages}`;
    updatePageNav(totalPages);
  }

  function applyTableFilter(resetPage = false) {
    if (resetPage) currentPage = 1;
    pageSize = Number(pageSizeSelect?.value || pageSize || 10);
    const q = (tableSearch && tableSearch.value || '').trim().toLowerCase();
    const userId = userFilter ? userFilter.value : '';
    const city = cityFilter ? cityFilter.value : '';
    if (tableSearchClear) tableSearchClear.classList.toggle('is-visible', q.length > 0);

    const rows = Array.from(tableRows());
    const matched = rows.filter((tr) => rowMatchesFilter(tr, q, userId, city));
    const totalPages = Math.max(1, Math.ceil(matched.length / pageSize));
    if (currentPage > totalPages) currentPage = totalPages;
    if (currentPage < 1) currentPage = 1;

    rows.forEach((tr) => { tr.style.display = 'none'; });
    matched.forEach((tr, idx) => {
      const page = Math.floor(idx / pageSize) + 1;
      if (page === currentPage) tr.style.display = '';
    });

    if (filteredGuestCountEl) {
      const total = rows.length;
      filteredGuestCountEl.textContent = total ? `${matched.length} / ${total}` : '';
    }
    updatePageInfo(matched.length, totalPages);
  }
  if (tableSearch) {
    tableSearch.addEventListener('input', () => applyTableFilter(true));
    tableSearch.addEventListener('search', () => applyTableFilter(true));
  }
  if (tableSearchClear && tableSearch) {
    tableSearchClear.addEventListener('click', () => {
      tableSearch.value = '';
      tableSearch.focus();
      applyTableFilter(true);
    });
  }
  if (userFilter) {
    userFilter.addEventListener('change', () => applyTableFilter(true));
  }
  if (cityFilter) {
    cityFilter.addEventListener('change', () => applyTableFilter(true));
  }
  if (pageSizeSelect) {
    pageSizeSelect.addEventListener('change', () => {
      pageSize = Number(pageSizeSelect.value || 10);
      applyTableFilter(true);
      document.getElementById('tableWrap')?.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
  if (pagePrev) {
    pagePrev.addEventListener('click', () => {
      if (currentPage <= 1) return;
      currentPage -= 1;
      applyTableFilter(false);
      document.getElementById('tableWrap')?.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
  if (pageNext) {
    pageNext.addEventListener('click', () => {
      currentPage += 1;
      applyTableFilter(false);
      document.getElementById('tableWrap')?.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
  document.querySelectorAll('.sort-btn').forEach((btn)=>{
    btn.addEventListener('click', ()=> setSort(btn.dataset.sortKey));
  });
  sortGuestTable();
  applyTableFilter();

  document.querySelectorAll('.invite-copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url || '';
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        const prev = btn.textContent;
        btn.textContent = 'OK';
        setTimeout(() => { btn.textContent = prev; }, 1500);
      } catch (err) {
        const ta = document.createElement('textarea');
        ta.value = url;
        ta.setAttribute('readonly', '');
        ta.style.position = 'fixed';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
    });
  });
  </script>
</body>
</html>
