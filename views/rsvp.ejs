<!doctype html>
<html lang="tr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Dugun Davetiyesi - LCV</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="min-h-screen bg-gradient-to-br from-rose-50 via-white to-indigo-50">
  <main class="max-w-lg mx-auto p-4 sm:p-8">
    <section class="rsvp-card bg-white rounded-3xl shadow-xl border border-rose-100 overflow-hidden">
      <div class="rsvp-header px-6 py-8 text-center text-white">
        <p class="text-sm uppercase tracking-widest opacity-90">Ozel Davetiye</p>
        <h1 class="text-2xl sm:text-3xl font-semibold mt-2">Katilim Bildirimi</h1>
        <p class="mt-3 text-sm opacity-90">Lutfen asagidaki formu doldurarak bize haber verin.</p>
      </div>

      <div class="px-6 py-6 space-y-5">
        <% if (submitted) { %>
        <div class="rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 text-sm">
          Katiliminiz basariyla kaydedildi. Tesekkur ederiz!
        </div>
        <% } %>

        <div id="rsvpError" class="hidden rounded-xl bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 text-sm"></div>
        <div id="rsvpSuccess" class="hidden rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 text-sm"></div>

        <form id="rsvpForm" class="space-y-5" novalidate>
          <div>
            <label for="guestName" class="block text-sm font-medium text-slate-700 mb-1.5">Adiniz Soyadiniz</label>
            <input
              type="text"
              id="guestName"
              name="name"
              class="rsvp-input w-full"
              placeholder="Isminizi yazin..."
              value="<%= guest.name || '' %>"
              autocomplete="name"
              required
            >
            <p class="mt-1.5 text-xs text-slate-500">Yazdiginiz isim listedeki kayitlarla karsilastirilir.</p>
          </div>

          <div id="matchPanel" class="hidden">
            <p class="text-sm font-medium text-slate-700 mb-2">Size yakin isimler</p>
            <div id="matchList" class="space-y-2"></div>
          </div>

          <input type="hidden" id="guestId" name="guest_id" value="<%= guest.id %>">

          <div id="selectedGuest" class="hidden rounded-xl bg-indigo-50 border border-indigo-200 px-4 py-3">
            <p class="text-xs uppercase tracking-wide text-indigo-600 font-medium">Secilen kayit</p>
            <p id="selectedGuestName" class="text-base font-semibold text-indigo-900 mt-1"></p>
          </div>

          <div id="declineWrap" class="rsvp-decline-wrap">
            <label for="notAttending" class="rsvp-decline-option flex items-start gap-3 rounded-xl border-2 border-rose-200 bg-rose-50 px-4 py-3 cursor-pointer">
              <input
                type="checkbox"
                id="notAttending"
                name="not_attending"
                class="mt-1 h-4 w-4 rounded border-rose-300 text-rose-600 focus:ring-rose-500"
                <%= Number(guest.status) === 3 ? "checked" : "" %>
              >
              <span class="text-sm text-slate-700">
                <span class="font-semibold text-rose-900">Davet'e katilamayacagim</span>
                <span class="block text-xs text-rose-700/80 mt-0.5">Isaretlerseniz kisi sayisi 0 olur ve katilamayacaginiz kaydedilir.</span>
              </span>
            </label>
          </div>

          <div id="partySizeWrap">
            <label for="partySize" class="block text-sm font-medium text-slate-700 mb-1.5">Toplam kac kisi ile geleceksiniz?</label>
            <select id="partySize" name="party_size" class="rsvp-input w-full" required></select>
            <p class="mt-1.5 text-xs text-slate-500">Kendiniz dahil toplam kisi sayisini secin.</p>
          </div>

          <div>
            <label for="rsvpNote" class="block text-sm font-medium text-slate-700 mb-1.5">Kisa not (istege bagli)</label>
            <textarea
              id="rsvpNote"
              name="note"
              class="rsvp-input w-full min-h-[5rem] resize-y"
              maxlength="500"
              placeholder="Ornegin: Vejetaryen menu, cocuklarla geliyoruz..."
            ><%= guest.rsvp_note || '' %></textarea>
          </div>

          <button type="submit" id="rsvpSubmit" class="rsvp-submit w-full">
            Katilimimi Bildir
          </button>
        </form>

        <% if (guest.rsvp_at) { %>
        <p class="text-xs text-center text-slate-400 pt-2">
          Son guncelleme: <%= new Date(guest.rsvp_at).toLocaleString('tr-TR') %>
        </p>
        <% } %>
      </div>
    </section>
  </main>

  <script>
  const TOKEN = <%- JSON.stringify(token) %>;
  const INITIAL_GUEST = <%- JSON.stringify({ id: guest.id, name: guest.name, status: guest.status, party_size: guest.party_size }) %>;
  const MAX_PARTY_SIZE = 5;
  const nameInput = document.getElementById('guestName');
  const guestIdInput = document.getElementById('guestId');
  const notAttendingInput = document.getElementById('notAttending');
  const partySizeSelect = document.getElementById('partySize');
  const matchPanel = document.getElementById('matchPanel');
  const matchList = document.getElementById('matchList');
  const selectedGuest = document.getElementById('selectedGuest');
  const selectedGuestName = document.getElementById('selectedGuestName');
  const rsvpForm = document.getElementById('rsvpForm');
  const rsvpError = document.getElementById('rsvpError');
  const rsvpSuccess = document.getElementById('rsvpSuccess');
  let searchTimer = null;
  let selectedMatch = INITIAL_GUEST;
  let savedPartySize = Math.min(Math.max(Number(INITIAL_GUEST.party_size || 1), 1), MAX_PARTY_SIZE);

  function buildPartySizeOptions(selectedValue) {
    partySizeSelect.replaceChildren();
    for (let i = 1; i <= MAX_PARTY_SIZE; i += 1) {
      const opt = document.createElement('option');
      opt.value = String(i);
      opt.textContent = `${i} kisi`;
      if (i === selectedValue) opt.selected = true;
      partySizeSelect.appendChild(opt);
    }
  }

  function setDeclineMode(decline) {
    if (decline) {
      if (!notAttendingInput.checked) {
        savedPartySize = Number(partySizeSelect.value || 1) || 1;
      }
      notAttendingInput.checked = true;
      partySizeSelect.replaceChildren();
      const opt = document.createElement('option');
      opt.value = '0';
      opt.textContent = '0 kisi';
      opt.selected = true;
      partySizeSelect.appendChild(opt);
      partySizeSelect.disabled = true;
      partySizeSelect.required = false;
      return;
    }
    notAttendingInput.checked = false;
    partySizeSelect.disabled = false;
    partySizeSelect.required = true;
    buildPartySizeOptions(savedPartySize);
  }

  function isDeclineMode() {
    return notAttendingInput.checked;
  }

  function showError(msg) {
    rsvpError.textContent = msg;
    rsvpError.classList.remove('hidden');
    rsvpSuccess.classList.add('hidden');
  }
  function showSuccess(msg) {
    rsvpSuccess.textContent = msg;
    rsvpSuccess.classList.remove('hidden');
    rsvpError.classList.add('hidden');
  }
  function clearMessages() {
    rsvpError.classList.add('hidden');
    rsvpSuccess.classList.add('hidden');
  }

  function selectGuest(match) {
    selectedMatch = match;
    guestIdInput.value = String(match.id);
    selectedGuestName.textContent = match.name;
    selectedGuest.classList.remove('hidden');
    matchPanel.classList.add('hidden');
  }

  function renderMatches(matches) {
    matchList.replaceChildren();
    if (!matches.length) {
      matchPanel.classList.add('hidden');
      return;
    }
    matches.forEach((match) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'rsvp-match-btn w-full text-left';
      btn.innerHTML = `<span class="font-medium">${match.name}</span><span class="text-xs text-slate-500 ml-2">Eslesme</span>`;
      btn.addEventListener('click', () => {
        nameInput.value = match.name;
        selectGuest(match);
      });
      matchList.appendChild(btn);
    });
    matchPanel.classList.remove('hidden');
  }

  async function searchNames(query) {
    const q = query.trim();
    if (q.length < 2) {
      matchPanel.classList.add('hidden');
      return;
    }
    const res = await fetch(`/api/rsvp/names?q=${encodeURIComponent(q)}`);
    const data = await res.json();
    if (!res.ok || !data.success) return;
    renderMatches(data.matches || []);
    const exact = (data.matches || []).find((m) => m.name.toLocaleLowerCase('tr') === q.toLocaleLowerCase('tr'));
    if (exact) selectGuest(exact);
  }

  nameInput.addEventListener('input', () => {
    clearMessages();
    selectedGuest.classList.add('hidden');
    guestIdInput.value = '';
    selectedMatch = null;
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => searchNames(nameInput.value), 280);
  });

  if (INITIAL_GUEST.name) {
    selectGuest(INITIAL_GUEST);
  }
  if (Number(INITIAL_GUEST.status) === 3) {
    setDeclineMode(true);
  } else {
    buildPartySizeOptions(savedPartySize);
  }

  notAttendingInput.addEventListener('change', () => {
    clearMessages();
    setDeclineMode(notAttendingInput.checked);
  });

  rsvpForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearMessages();
    const name = nameInput.value.trim();
    const guestId = Number(guestIdInput.value || 0);
    const decline = isDeclineMode();
    const partySize = decline ? 0 : Number(partySizeSelect.value || 0);
    const note = document.getElementById('rsvpNote').value.trim();
    if (!name) {
      showError('Lutfen isminizi yazin.');
      nameInput.focus();
      return;
    }
    if (!guestId) {
      showError('Lutfen listeden size uygun ismi secin.');
      nameInput.focus();
      return;
    }
    const submitBtn = document.getElementById('rsvpSubmit');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Kaydediliyor...';
    try {
      const res = await fetch(`/api/rsvp/${TOKEN}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ guest_id: guestId, name, party_size: partySize, not_attending: decline, note })
      });
      const data = await res.json();
      if (!res.ok || !data.success) {
        showError(data.message || 'Kayit basarisiz oldu.');
        return;
      }
      showSuccess(data.message || (decline ? 'Katilamayacaginiz kaydedildi.' : 'Katiliminiz kaydedildi.'));
      if (data.guest) {
        selectGuest(data.guest);
        if (Number(data.guest.status) === 3 || Number(data.guest.party_size) === 0) {
          setDeclineMode(true);
        } else {
          savedPartySize = Number(data.guest.party_size || 1);
          setDeclineMode(false);
        }
      }
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } catch (err) {
      showError('Baglanti hatasi. Lutfen tekrar deneyin.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Katilimimi Bildir';
    }
  });
  </script>
</body>
</html>
