<!doctype html>
<html lang="<%= locale %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= t('meta.title') %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="<%= typeof basePath !== 'undefined' ? basePath : '' %>/style.css">
</head>
<body class="rsvp-page">
  <main class="rsvp-main">
    <section class="rsvp-card">
      <div class="rsvp-header">
        <nav class="rsvp-lang-switch" aria-label="Language">
          <a href="<%= typeof basePath !== 'undefined' ? basePath : '' %>/davet/<%= token %>?lang=tr<%= submitted ? '&ok=1' : '' %>" class="rsvp-lang-btn<%= locale === 'tr' ? ' is-active' : '' %>"><%= t('lang.tr') %></a>
          <span class="rsvp-lang-sep" aria-hidden="true">|</span>
          <a href="<%= typeof basePath !== 'undefined' ? basePath : '' %>/davet/<%= token %>?lang=de<%= submitted ? '&ok=1' : '' %>" class="rsvp-lang-btn<%= locale === 'de' ? ' is-active' : '' %>"><%= t('lang.de') %></a>
        </nav>
        <div class="rsvp-ornament" aria-hidden="true">
          <span class="rsvp-ornament-line"></span>
          <span class="rsvp-ornament-diamond"></span>
          <span class="rsvp-ornament-line"></span>
        </div>
        <p class="rsvp-badge"><%= t('rsvp.headerBadge') %></p>
        <h1 class="rsvp-couple">Zeynep <span class="rsvp-amp">&amp;</span> Enis</h1>
        <p class="rsvp-date">16.01.2027</p>
        <p class="rsvp-intro"><%= t('rsvp.intro') %></p>
      </div>

      <div class="rsvp-body">
        <% if (submitted) { %>
        <div class="rsvp-alert rsvp-alert-success">
          <%= t('rsvp.successPage') %>
        </div>
        <% } %>

        <div id="rsvpError" class="rsvp-alert rsvp-alert-error hidden"></div>
        <div id="rsvpSuccess" class="rsvp-alert rsvp-alert-success hidden"></div>

        <div id="calendarSuggest" class="<%= showCalendar ? '' : 'hidden' %> rsvp-calendar-suggest">
          <div>
            <p class="rsvp-calendar-title"><%= t('rsvp.calendarTitle') %></p>
            <p class="rsvp-calendar-meta"><%= calendar.title %> · 16.01.2027 · 16:00 – 23:00</p>
          </div>
          <div class="rsvp-calendar-actions">
            <a id="googleCalendarBtn" class="rsvp-calendar-btn" href="#" target="_blank" rel="noopener noreferrer"><%= t('rsvp.googleCalendar') %></a>
            <a class="rsvp-calendar-btn rsvp-calendar-btn-secondary" href="<%= typeof basePath !== 'undefined' ? basePath : '' %>/davet/<%= token %>/takvim.ics"><%= t('rsvp.downloadIcs') %></a>
          </div>
        </div>

        <form id="rsvpForm" class="rsvp-form" novalidate>
          <input type="hidden" id="guestId" name="guest_id" value="<%= guest.id %>">

          <div class="rsvp-guest-box">
            <p class="rsvp-field-label"><%= t('rsvp.guestLabel') %></p>
            <p id="selectedGuestName" class="rsvp-guest-name"><%= guest.name %></p>
          </div>

          <div id="declineWrap" class="rsvp-decline-wrap">
            <label for="notAttending" class="rsvp-decline-option">
              <input
                type="checkbox"
                id="notAttending"
                name="not_attending"
                class="rsvp-decline-checkbox"
                <%= Number(guest.status) === 3 ? "checked" : "" %>
              >
              <span class="rsvp-decline-text">
                <span class="rsvp-decline-title"><%= t('rsvp.declineTitle') %></span>
                <span class="rsvp-decline-hint"><%= t('rsvp.declineHint') %></span>
              </span>
            </label>
          </div>

          <div id="partySizeWrap" class="rsvp-field">
            <label for="partySize" class="rsvp-field-label"><%= t('rsvp.partySizeLabel') %></label>
            <select id="partySize" name="party_size" class="rsvp-input" required></select>
            <p class="rsvp-field-hint"><%= t('rsvp.partySizeHint') %></p>
          </div>

          <div class="rsvp-field">
            <label for="rsvpNote" class="rsvp-field-label"><%= t('rsvp.noteLabel') %></label>
            <textarea
              id="rsvpNote"
              name="note"
              class="rsvp-input rsvp-textarea"
              maxlength="500"
              placeholder="<%= t('rsvp.notePlaceholder') %>"
            ><%= guest.rsvp_note || '' %></textarea>
          </div>

          <button type="submit" id="rsvpSubmit" class="rsvp-submit">
            <%= t('rsvp.submit') %>
          </button>
        </form>

        <% if (guest.rsvp_at) { %>
        <p class="rsvp-footer-note">
          <%= t('rsvp.lastUpdate') %> <%= new Date(guest.rsvp_at).toLocaleString(dateLocale) %>
        </p>
        <% } %>
      </div>
    </section>
  </main>

  <script>
  const TOKEN = <%- JSON.stringify(token) %>;
  const INITIAL_GUEST = <%- JSON.stringify({ id: guest.id, name: guest.name, status: guest.status, party_size: guest.party_size }) %>;
  const WEDDING_CALENDAR = <%- JSON.stringify(calendar) %>;
  const SHOW_CALENDAR_INIT = <%= showCalendar ? 'true' : 'false' %>;
  const I18N = <%- JSON.stringify(i18n.rsvp) %>;
  const MAX_PARTY_SIZE = 5;
  const guestIdInput = document.getElementById('guestId');
  const notAttendingInput = document.getElementById('notAttending');
  const partySizeSelect = document.getElementById('partySize');
  const selectedGuestName = document.getElementById('selectedGuestName');
  const rsvpForm = document.getElementById('rsvpForm');
  const rsvpError = document.getElementById('rsvpError');
  const rsvpSuccess = document.getElementById('rsvpSuccess');
  const calendarSuggest = document.getElementById('calendarSuggest');
  const googleCalendarBtn = document.getElementById('googleCalendarBtn');
  let savedPartySize = Math.min(Math.max(Number(INITIAL_GUEST.party_size || 1), 1), MAX_PARTY_SIZE);

  function personCountLabel(n) {
    return I18N.personCount.replace('{{n}}', String(n));
  }

  function googleCalendarUrl() {
    const params = new URLSearchParams({
      action: 'TEMPLATE',
      text: WEDDING_CALENDAR.title,
      dates: `${WEDDING_CALENDAR.date}T${WEDDING_CALENDAR.start}/${WEDDING_CALENDAR.date}T${WEDDING_CALENDAR.end}`,
      ctz: WEDDING_CALENDAR.timezone
    });
    return `https://calendar.google.com/calendar/render?${params.toString()}`;
  }

  if (googleCalendarBtn) {
    googleCalendarBtn.href = googleCalendarUrl();
  }

  function showCalendarSuggest(show) {
    if (!calendarSuggest) return;
    calendarSuggest.classList.toggle('hidden', !show);
  }

  function buildPartySizeOptions(selectedValue) {
    partySizeSelect.replaceChildren();
    for (let i = 1; i <= MAX_PARTY_SIZE; i += 1) {
      const opt = document.createElement('option');
      opt.value = String(i);
      opt.textContent = personCountLabel(i);
      if (i === selectedValue) opt.selected = true;
      partySizeSelect.appendChild(opt);
    }
  }

  function setDeclineMode(decline) {
    if (decline) {
      if (!notAttendingInput.checked) {
        savedPartySize = Number(partySizeSelect.value || 1) || 1;
      }
      notAttendingInput.checked = true;
      partySizeSelect.replaceChildren();
      const opt = document.createElement('option');
      opt.value = '0';
      opt.textContent = I18N.personCountZero;
      opt.selected = true;
      partySizeSelect.appendChild(opt);
      partySizeSelect.disabled = true;
      partySizeSelect.required = false;
      return;
    }
    notAttendingInput.checked = false;
    partySizeSelect.disabled = false;
    partySizeSelect.required = true;
    buildPartySizeOptions(savedPartySize);
  }

  function isDeclineMode() {
    return notAttendingInput.checked;
  }

  function showError(msg) {
    rsvpError.textContent = msg;
    rsvpError.classList.remove('hidden');
    rsvpSuccess.classList.add('hidden');
  }
  function showSuccess(msg) {
    rsvpSuccess.textContent = msg;
    rsvpSuccess.classList.remove('hidden');
    rsvpError.classList.add('hidden');
  }
  function clearMessages() {
    rsvpError.classList.add('hidden');
    rsvpSuccess.classList.add('hidden');
  }

  function updateCalendarVisibility(decline) {
    showCalendarSuggest(!decline);
  }

  if (Number(INITIAL_GUEST.status) === 3) {
    setDeclineMode(true);
    showCalendarSuggest(false);
  } else {
    buildPartySizeOptions(savedPartySize);
    showCalendarSuggest(SHOW_CALENDAR_INIT);
  }

  notAttendingInput.addEventListener('change', () => {
    clearMessages();
    setDeclineMode(notAttendingInput.checked);
    updateCalendarVisibility(notAttendingInput.checked);
  });

  rsvpForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearMessages();
    const guestId = Number(guestIdInput.value || INITIAL_GUEST.id);
    const decline = isDeclineMode();
    const partySize = decline ? 0 : Number(partySizeSelect.value || 0);
    const note = document.getElementById('rsvpNote').value.trim();
    const submitBtn = document.getElementById('rsvpSubmit');
    submitBtn.disabled = true;
    submitBtn.textContent = I18N.saving;
    try {
      const res = await fetch(`<%= typeof basePath !== 'undefined' ? basePath : '' %>/api/rsvp/${TOKEN}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          guest_id: guestId,
          name: INITIAL_GUEST.name,
          party_size: partySize,
          not_attending: decline,
          note
        })
      });
      const data = await res.json();
      if (!res.ok || !data.success) {
        showError(data.message || I18N.saveFailed);
        return;
      }
      showSuccess(data.message || (decline ? I18N.declineSaved : I18N.attendanceSaved));
      if (data.guest?.name) selectedGuestName.textContent = data.guest.name;
      if (Number(data.guest?.status) === 3 || Number(data.guest?.party_size) === 0) {
        setDeclineMode(true);
        showCalendarSuggest(false);
      } else if (data.guest) {
        savedPartySize = Number(data.guest.party_size || 1);
        setDeclineMode(false);
        showCalendarSuggest(true);
      }
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } catch (err) {
      showError(I18N.connectionError);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = I18N.submit;
    }
  });
  </script>
</body>
</html>
